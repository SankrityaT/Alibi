SUPERMEMORY_BASE_URL=http://localhost:6767
SUPERMEMORY_API_KEY=replace-with-key-from-first-boot
# No ANTHROPIC_API_KEY needed. Claude auth is handled by the Claude Agent SDK,
# which uses the `claude` CLI's local login (run `claude login` once on this
# machine) and draws on your Claude subscription instead of a billed API key.

# Model-provider key for Supermemory's memory-EXTRACTION step (the "memory
# agent"). The memory layer itself — embeddings, storage, search — is fully
# local; only turning raw text into memory rows needs an LLM. Used by
# scripts/start-supermemory.sh. Swap to a local model any time by pointing
# Supermemory at Ollama (OPENAI_BASE_URL=http://localhost:11434/v1,
# OPENAI_MODEL=gpt-oss:20b) instead of a key.
SUPERMEMORY_MODEL_API_KEY=replace-with-openai-key

# Suspect voices. If set, /api/tts uses OpenAI TTS (good voices, no local
# model). Leave unset to fall back to a local Kokoro server (KOKORO_BASE_URL),
# and finally to the browser's built-in speech — the transcript always works.
TTS_OPENAI_API_KEY=replace-with-openai-key
# KOKORO_BASE_URL=http://localhost:8880

# Local whisper.cpp STT server (optional voice input for the player's
# questions). Leave unset to run without voice input — /api/stt degrades to a
# 503 and the player just types their question. To enable voice input, build
# whisper.cpp and start its bundled HTTP server:
#   git clone https://github.com/ggerganov/whisper.cpp && cd whisper.cpp
#   make -j && ./models/download-ggml-model.sh base.en
#   ./build/bin/whisper-server -m models/ggml-base.en.bin --port 8081
# then set the URL below (whisper.cpp exposes POST /inference for audio).
WHISPER_BASE_URL=http://localhost:8081
